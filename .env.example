# --- Server ---
PORT=3000

# --- MongoDB (required for rides/status) ---
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/smart-cycle-lock
# NOTE: Do not use a localhost/127.0.0.1 URI on Vercel/production.
MONGODB_URI=

# --- Razorpay (required for real payments) ---
# Use Razorpay Test keys while developing.
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# If you want to run the app without Razorpay configured (demo mode only)
# ALLOW_SIMULATED_PAYMENT=true

# --- SMS (Twilio) ---
# Enable/disable sending SMS confirmations
SMS_ENABLED=false

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number (E.164), e.g. +14155552671
TWILIO_FROM_NUMBER=
